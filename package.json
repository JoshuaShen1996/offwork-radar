{
  "name": "offwork-radar",
  "version": "0.1.2",
  "description": "跑路准时宝 - cross-platform desktop widget for commute and weather reminders.",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "icons": "node scripts/generate-icons.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win nsis portable",
    "build:mac": "electron-builder --mac dmg zip",
    "build:dir": "electron-builder --dir"
  },
  "keywords": [
    "electron",
    "commute",
    "weather",
    "amap"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.codex.offworkradar",
    "productName": "跑路准时宝",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
