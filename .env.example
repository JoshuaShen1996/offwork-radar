# 高德 Web 服务 Key（不填则使用演示数据）
AMAP_KEY=your_amap_web_service_key

# 高德可交互地图（Web端 JS API，可选；不填则用静态地图）
AMAP_JS_KEY=
AMAP_SECURITY_CODE=

# 和风天气 QWeather（可选，逐小时天气 + 降水概率 + 体感温度；不填则用高德白天/夜间）
QWEATHER_KEY=
QWEATHER_HOST=https://devapi.qweather.com

# AI 一句话决策（可选，OpenAI 兼容接口，可指向公司内部模型）
# 留空则用规则文案，不影响主流程
AI_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
